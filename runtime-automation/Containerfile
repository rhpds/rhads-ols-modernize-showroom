FROM quay.io/agnosticd/ee-multicloud:chained-2026-04-01

USER root

# Install Flask and Flask-CORS for the API server
RUN /usr/local/bin/pip3 install \
    flask==3.0.0 \
    flask-cors==4.0.0

# Copy API server
COPY api-server.py /app/
RUN chmod +x /app/api-server.py

# Create playbooks directory (will be mounted from volume)
RUN mkdir -p /playbooks

# Switch to non-root user (EE image uses runner user)
USER 1000

WORKDIR /app

EXPOSE 5000

CMD ["python3", "/app/api-server.py"]
